rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Projects ──────────────────────────────────────────────
    match /projects/{projectId} {
      // Anyone can read projects
      allow read: if true;
      // Only admin/mod can create or update projects
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'mod'];

      // ── Check-ins (sub-collection) ─────────────────────────
      match /checkins/{checkinId} {
        // Anyone can read check-ins
        allow read: if true;
        // Authenticated users can create check-ins
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
        // Users can update/delete only their own check-ins
        allow update, delete: if request.auth != null
          && resource.data.userId == request.auth.uid;
      }
    }

    // ── Users ─────────────────────────────────────────────────
    match /users/{userId} {
      // Users can read their own doc; admins can read any
      allow read: if request.auth != null
        && (request.auth.uid == userId
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      // Users can create/update their own doc
      allow create, update: if request.auth != null
        && request.auth.uid == userId;

      // ── Bookmarks (sub-collection) ─────────────────────────
      match /bookmarks/{projectId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }
    }

    // ── Reports (optional moderation) ─────────────────────────
    match /reports/{reportId} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'mod'];
      allow create: if request.auth != null;
    }
  }
}
